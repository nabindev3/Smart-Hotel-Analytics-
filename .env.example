# ─────────────────────────────────────────────────────────────────
#  Smart Hotel Analytics — environment variables
# ─────────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in real values:
#      cp .env.example .env
#  Docker Compose auto-loads .env from the project root.
#
#  Don't commit .env — it's already in .gitignore (or should be).
# ─────────────────────────────────────────────────────────────────

# ─── Sentiment / NLP ─────────────────────────────────────────────
# Tier 1 — HuggingFace Inference API (recommended, free, sarcasm + aspect)
#   Get a token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Tier 2 — Claude API (fallback if HF_API_TOKEN absent or rate-limited)
#   Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Tier 3 — TextBlob is always available locally, no key needed.
